<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#00000000"/> <stroke android:width="3dp" android:color="@color/rouge_pink"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>

    <item android:bottom="4dp" android:left="4dp" android:right="4dp" android:top="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#00000000"/> <stroke android:width="1dp" android:color="@color/gold_thread"/>
            <corners android:radius="12dp"/>
        </shape>
    </item>
</layer-list>