<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212"
    android:fitsSystemWindows="true"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/bg_dark_glass"
        android:padding="20dp"
        android:gravity="center_vertical">

        <androidx.cardview.widget.CardView
            android:id="@+id/cv_mine_avatar"
            android:layout_width="80dp"
            android:layout_height="80dp"
            app:cardCornerRadius="40dp"
            app:cardBackgroundColor="#33000000">
            <ImageView
                android:id="@+id/iv_mine_avatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_launcher_background" />
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="20dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_mine_nickname"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="未登录"
                android:textColor="#E5C07B"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_mine_username"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ID: --"
                android:textColor="#9E9E9E"
                android:textSize="12sp"
                android:layout_marginTop="4dp" />
            <TextView
                android:id="@+id/tv_sync_data"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔄重新获取昵称和头像"
                android:textColor="#64B5F6"
                android:textSize="11sp"
                android:layout_marginTop="8dp"
                android:paddingVertical="4dp"
                android:paddingEnd="8dp"
                android:visibility="gone" />
            <Button
                android:id="@+id/btn_one_click_login"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:backgroundTint="#E5C07B"
                android:textColor="#121212"
                android:text="一键创建/登录该设备账号"
                android:visibility="gone"/>
        </LinearLayout>

        <ImageView
            android:id="@+id/btn_edit_profile"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="4dp"
            android:src="@android:drawable/ic_menu_edit"
            app:tint="#9E9E9E" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="其他功能"
        android:textColor="#E0E0E0"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginTop="30dp"
        android:layout_marginBottom="10dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:background="@drawable/bg_dark_hollow"
        android:gravity="center"
        android:text="更多功能待开发中...\n(如：我的收藏、我的发布、设置等)"
        android:textColor="#555555"
        android:textSize="14sp" />
</LinearLayout>