<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingVertical="4dp">

    <TextView
        android:id="@+id/tv_upload_turn_num"
        android:layout_width="30dp"
        android:layout_height="wrap_content"
        android:text="1"
        android:textColor="#E5C07B"
        android:textSize="13sp"
        android:textStyle="bold"
        android:gravity="center" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#1AFFFFFF"
        android:paddingHorizontal="4dp"
        android:paddingVertical="2dp">

        <TextView android:id="@+id/tv_up_act_1" android:layout_width="22dp" android:layout_height="wrap_content" android:text="A" android:textColor="#E0E0E0" android:textSize="12sp" android:gravity="center"/>
        <TextView android:id="@+id/tv_up_act_2" android:layout_width="22dp" android:layout_height="wrap_content" android:text="1↓" android:textColor="#E0E0E0" android:textSize="12sp" android:gravity="center"/>
        <TextView android:id="@+id/tv_up_act_3" android:layout_width="22dp" android:layout_height="wrap_content" android:text="-" android:textColor="#666666" android:textSize="12sp" android:gravity="center"/>
        <TextView android:id="@+id/tv_up_act_4" android:layout_width="22dp" android:layout_height="wrap_content" android:text="A" android:textColor="#E0E0E0" android:textSize="12sp" android:gravity="center"/>
        <TextView android:id="@+id/tv_up_act_5" android:layout_width="22dp" android:layout_height="wrap_content" android:text="4↑" android:textColor="#E0E0E0" android:textSize="12sp" android:gravity="center"/>
    </LinearLayout>

    <EditText
        android:id="@+id/et_upload_remark"
        android:layout_width="0dp"
        android:layout_height="26dp"
        android:layout_weight="1"
        android:layout_marginStart="10dp"
        android:background="@drawable/bg_dark_hollow"
        android:hint="点击添加备注..."
        android:textColorHint="#666666"
        android:textColor="#A0A0A0"
        android:textSize="11sp"
        android:paddingHorizontal="8dp"
        android:singleLine="true"/>
</LinearLayout>