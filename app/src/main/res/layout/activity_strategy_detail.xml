<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/background"
        android:contentDescription="@null" />
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000" /> <include
    layout="@layout/layout_top_bar"
    android:id="@+id/top_bar"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_alignParentTop="true" />

    <LinearLayout
        android:id="@+id/layout_bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:background="@drawable/bg_dark_glass_flat" android:gravity="center_vertical"
        android:paddingHorizontal="15dp"
        android:elevation="10dp">

        <LinearLayout
            android:id="@+id/btn_like"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingEnd="15dp">

            <TextView
                android:id="@+id/tv_like_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="♡"
                android:textSize="22sp"
                android:textColor="#E5C07B" />
            <TextView
                android:id="@+id/tv_like_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="赞"
                android:textColor="#E5C07B"
                android:textSize="14sp"
                android:layout_marginStart="5dp"/>
        </LinearLayout>

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>

        <Button
            android:id="@+id/btn_copy_url"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="原帖链接"
            android:background="@drawable/btn_dark_hollow"
            android:textColor="#E0E0E0"
            android:textSize="13sp"
            android:visibility="gone"
            android:layout_marginEnd="10dp"/>

        <Button
            android:id="@+id/btn_import_script"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="导入脚本"
            android:background="@drawable/btn_dark_gold"
            android:textColor="#1A1A1A"
            android:textSize="13sp"
            android:visibility="gone"
            android:textStyle="bold"/>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/layout_bottom_bar"
        android:layout_below="@id/top_bar"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <RelativeLayout
                android:id="@+id/layout_image_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:visibility="gone">

                <androidx.viewpager2.widget.ViewPager2
                    android:id="@+id/vp_detail_images"
                    android:layout_width="match_parent"
                    android:layout_height="350dp" />

                <TextView
                    android:id="@+id/tv_image_indicator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/vp_detail_images"
                    android:layout_centerHorizontal="true"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_dark_glass"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:text="1/1"
                    android:textColor="#E5C07B"
                    android:textSize="12sp"
                    android:textStyle="bold"/>
            </RelativeLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="◆ 出战阵容"
                android:textColor="#E5C07B"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="15dp"/>

            <LinearLayout
                android:id="@+id/layout_agents_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="top|center_horizontal"
                android:baselineAligned="false"
                android:layout_marginBottom="25dp"> </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_dark_glass"
                android:padding="15dp"
                android:layout_marginBottom="30dp">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_detail_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:overScrollMode="never" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</RelativeLayout>