<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="#E5C07B"
            android:textSize="32sp"
            android:textStyle="bold"
            android:fontFamily="serif"
            android:gravity="center"
            android:layout_marginTop="30dp"
            android:layout_marginBottom="30dp"
            android:letterSpacing="0.15"
            android:shadowColor="#000000"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="4"/>

        <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/bg_dark_glass" android:layout_marginBottom="20dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/title_combat_mode" android:textColor="#E5C07B" android:textSize="18sp" android:textStyle="bold" android:fontFamily="serif" android:layout_marginBottom="15dp"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                    <Button android:id="@+id/btn_main_start_combat" android:layout_width="0dp" android:layout_weight="1.5" android:layout_height="50dp" android:text="@string/btn_start_combat" android:textColor="#1A1A1A" android:background="@drawable/btn_dark_gold" android:fontFamily="serif" android:textStyle="bold" android:textSize="16sp" android:layout_marginEnd="10dp"/>
                    <Button android:id="@+id/btn_main_combat_settings" android:layout_width="0dp" android:layout_weight="1" android:layout_height="50dp" android:text="@string/btn_settings" android:textColor="#E5C07B" android:background="@drawable/btn_dark_hollow" android:fontFamily="serif" android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>

        <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/bg_dark_glass" android:layout_marginBottom="20dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/title_daily_mode" android:textColor="#E0E0E0" android:textSize="18sp" android:textStyle="bold" android:fontFamily="serif" android:layout_marginBottom="15dp"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                    <Button android:id="@+id/btn_main_start_daily" android:layout_width="0dp" android:layout_weight="1.5" android:layout_height="50dp" android:text="@string/btn_start_daily" android:textColor="#888888" android:background="@drawable/btn_dark_hollow" android:fontFamily="serif" android:textStyle="bold" android:textSize="16sp" android:layout_marginEnd="10dp"/>
                    <Button android:id="@+id/btn_main_daily_settings" android:layout_width="0dp" android:layout_weight="1" android:layout_height="50dp" android:text="@string/btn_settings" android:textColor="#E0E0E0" android:background="@drawable/btn_dark_hollow" android:fontFamily="serif" android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>

        <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/bg_dark_glass" android:layout_marginBottom="20dp">
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="2"
                android:padding="15dp"
                android:useDefaultMargins="true">

                <Button
                    android:id="@+id/btn_main_scripts"
                    android:text="已录制脚本"
                    android:background="@drawable/btn_dark_hollow"
                    android:textColor="#E5C07B"
                    android:textStyle="bold"
                    android:fontFamily="serif"
                    android:layout_columnWeight="1"
                    android:layout_height="45dp"
                    android:layout_margin="4dp"/>

                <Button
                    android:id="@+id/btn_main_tutorial"
                    android:text="运行日志"
                    android:background="@drawable/btn_dark_hollow"
                    android:textColor="#E5C07B"
                    android:textStyle="bold"
                    android:fontFamily="serif"
                    android:layout_columnWeight="1"
                    android:layout_height="45dp"
                    android:layout_margin="4dp"/>

                <Button
                    android:id="@+id/btn_main_update"
                    android:text="检查更新"
                    android:background="@drawable/btn_dark_hollow"
                    android:textColor="#E5C07B"
                    android:textStyle="bold"
                    android:fontFamily="serif"
                    android:layout_columnWeight="1"
                    android:layout_height="45dp"
                    android:layout_margin="4dp"/>

                <Button
                    android:id="@+id/btn_main_theme"
                    android:text="功能测试"
                    android:background="@drawable/btn_dark_hollow"
                    android:textColor="#E5C07B"
                    android:textStyle="bold"
                    android:fontFamily="serif"
                    android:layout_columnWeight="1"
                    android:layout_height="45dp"
                    android:layout_margin="4dp"/>
            </GridLayout>
        </FrameLayout>

        <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/bg_dark_glass" android:layout_marginBottom="20dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="活动倒计时" android:textColor="#E5C07B" android:textSize="18sp" android:textStyle="bold" android:fontFamily="serif" android:layout_marginBottom="10dp"/>
                <androidx.recyclerview.widget.RecyclerView android:id="@+id/rv_ddl_list" android:layout_width="match_parent" android:layout_height="wrap_content" android:nestedScrollingEnabled="false" android:overScrollMode="never" />
            </LinearLayout>
        </FrameLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>