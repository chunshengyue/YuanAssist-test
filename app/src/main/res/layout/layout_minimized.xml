<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cv_minimized_root"
    android:layout_width="wrap_content"
    android:layout_height="50dp"
    app:cardCornerRadius="25dp"
    app:cardElevation="6dp"
    app:cardBackgroundColor="#FDFDFD">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/iv_mini_drag_handle"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/ic_float_logo"
            android:scaleType="fitCenter"
            android:padding="0dp"
            android:background="@android:color/transparent"/>

        <LinearLayout
            android:id="@+id/layout_mini_controls"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone"
            tools:visibility="visible">

            <View android:layout_width="1dp" android:layout_height="20dp" android:background="#DDDDDD"/>

            <ImageButton
                android:id="@+id/btn_mini_stop"
                android:layout_width="45dp"
                android:layout_height="match_parent"
                android:src="@drawable/ic_stop"
                android:background="@android:color/transparent"
                android:scaleType="centerInside"
                android:padding="12dp"/>

            <View android:layout_width="1dp" android:layout_height="20dp" android:background="#DDDDDD"/>

            <ImageButton
                android:id="@+id/btn_mini_action"
                android:layout_width="45dp"
                android:layout_height="match_parent"
                android:src="@drawable/ic_next_turn_chevron"
                android:background="@android:color/transparent"
                android:scaleType="centerInside"
                android:padding="10dp"/>

            <View android:layout_width="1dp" android:layout_height="20dp" android:background="#DDDDDD"/>

            <TextView
                android:id="@+id/tv_mini_info"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="16dp"
                tools:text="T1 执行中"
                android:textColor="#4A6F8A"
                android:textSize="13sp"
                android:textStyle="bold"
                android:fontFamily="serif"
                android:maxLines="1"/>

        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>