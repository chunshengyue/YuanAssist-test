<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@android:color/transparent">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="5dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <EditText
                android:id="@+id/et_search_keyword"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="45dp"
                android:background="@drawable/bg_dark_glass"
                android:hint="输入关卡或密探名称搜索..."
                android:textColorHint="#888888"
                android:textColor="#E5C07B"
                android:paddingStart="15dp"
                android:paddingEnd="15dp"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btn_search"
                android:layout_width="70dp"
                android:layout_height="45dp"
                android:text="搜索"
                android:textColor="#1A1A1A"
                android:background="@drawable/btn_dark_gold"
                android:textStyle="bold"
                android:layout_marginStart="10dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <TextView
                android:id="@+id/tv_filter_ruyuan"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="如鸢"
                android:gravity="center"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textColor="#E5C07B"
                android:background="@drawable/btn_dark_hollow"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/tv_filter_daihao"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="代号鸢"
                android:gravity="center"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textColor="#E5C07B"
                android:background="@drawable/btn_dark_hollow"
                android:textSize="12sp"
                android:textStyle="bold"/>

            <Space
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

            <CheckBox
                android:id="@+id/cb_default_filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="默认过滤"
                android:textColor="#E5C07B"
                android:textSize="12sp"
                android:checked="true"
                android:buttonTint="#E5C07B"
                android:layout_marginEnd="10dp"/>

            <LinearLayout
                android:id="@+id/btn_advanced_filter"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:gravity="center"
                android:background="@drawable/bg_dark_glass"
                android:paddingStart="10dp"
                android:paddingEnd="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="≡ 筛选"
                    android:textColor="#E5C07B"
                    android:textSize="12sp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_strategy_list"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:overScrollMode="never"/>

    </LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_upload_strategy"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="30dp"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="#E5C07B"
        app:tint="#1A1A1A"
        android:contentDescription="上传攻略"
        app:elevation="6dp"
        app:pressedTranslationZ="12dp"/>

</RelativeLayout>