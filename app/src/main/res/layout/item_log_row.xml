<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="30dp"
    android:orientation="horizontal"
    android:background="@color/gold_thread"
    android:paddingStart="1dp"
    android:paddingEnd="1dp"

    android:paddingBottom="1dp">

    <TextView
        android:id="@+id/tv_round_index"
        android:layout_width="45dp"
        android:layout_height="match_parent"
        android:background="#FFFFFF"
        android:gravity="center"
        android:text="1"
        android:textColor="@color/palace_blue"
        android:textSize="12sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif"
        android:layout_marginEnd="1dp"/>

    <TextView
        android:id="@+id/tv_col_1"
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="match_parent"
        android:background="#FFFFFF"
        android:gravity="center"
        android:padding="2dp"
        android:text="1A"
        android:textColor="@color/palace_blue"
        android:textSize="10sp"
        android:fontFamily="sans-serif"
        android:layout_marginEnd="1dp"/>

    <TextView
        android:id="@+id/tv_col_2"
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="match_parent"
        android:background="#FFFFFF"
        android:gravity="center"
        android:padding="2dp"
        android:text="2A"
        android:textColor="@color/palace_blue"
        android:textSize="10sp"
        android:fontFamily="sans-serif"
        android:layout_marginEnd="1dp"/>

    <TextView
        android:id="@+id/tv_col_3"
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="match_parent"
        android:background="#FFFFFF"
        android:gravity="center"
        android:padding="2dp"
        android:text="3A"
        android:textColor="@color/palace_blue"
        android:textSize="10sp"
        android:fontFamily="sans-serif"
        android:layout_marginEnd="1dp"/>

    <TextView
        android:id="@+id/tv_col_4"
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="match_parent"
        android:background="#FFFFFF"
        android:gravity="center"
        android:padding="2dp"
        android:text="4A"
        android:textColor="@color/palace_blue"
        android:textSize="10sp"
        android:fontFamily="sans-serif"
        android:layout_marginEnd="1dp"/>

    <TextView
        android:id="@+id/tv_col_5"
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="match_parent"
        android:background="#FFFFFF"
        android:gravity="center"
        android:padding="2dp"
        android:text="5A"
        android:textColor="@color/palace_blue"
        android:textSize="10sp"
        android:fontFamily="sans-serif"/>

</LinearLayout>